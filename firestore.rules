rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSuperAdminEmail() {
      return signedIn() && request.auth.token.email == "rahul.jain.en@gmail.com";
    }

    function signedIn() {
      return request.auth != null;
    }

    function isLeagueAdmin(leagueId) {
      return signedIn()
        && get(/databases/$(database)/documents/leagues/$(leagueId)).data.adminUid == request.auth.uid;
    }

    function isLeagueMember(leagueId) {
      return signedIn()
        && (
          isLeagueAdmin(leagueId)
          || exists(/databases/$(database)/documents/leagueMembers/$(leagueId + "_" + request.auth.uid))
        );
    }

    function isAppAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function matchDeadlineIsOpen(leagueId, matchId) {
      let match = get(/databases/$(database)/documents/matches/$(matchId)).data;
      return match.leagueId == leagueId
        && match.deadlineEpochMs is int
        && request.time.toMillis() < match.deadlineEpochMs;
    }

    match /users/{userId} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (
          request.resource.data.role == "user"
          || (isSuperAdminEmail() && request.resource.data.role == "superadmin")
        );

      allow read: if signedIn() && (request.auth.uid == userId || isSuperAdminEmail());

      allow update: if signedIn()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && (
          (
            request.auth.uid == userId
            && (
              request.resource.data.role == resource.data.role
              || (isSuperAdminEmail() && request.resource.data.role == "superadmin")
            )
          )
          || (
            isSuperAdminEmail()
            && request.resource.data.role in ["user", "admin", "superadmin"]
          )
        );
    }

    match /leagues/{leagueId} {
      allow create: if signedIn()
        && isAppAdmin()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0] == request.auth.uid;
      allow read: if signedIn();
      allow update: if isLeagueAdmin(leagueId);
      allow delete: if isLeagueAdmin(leagueId);
    }

    match /leagueMembers/{memberId} {
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isLeagueAdmin(resource.data.leagueId)
        );

      allow create: if signedIn()
        && isLeagueAdmin(request.resource.data.leagueId)
        && request.resource.data.role == "member";

      allow update, delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isLeagueAdmin(resource.data.leagueId)
        );
    }

    match /leagueRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "pending"
        && !exists(/databases/$(database)/documents/leagueRequests/$(requestId))
        && !isLeagueMember(request.resource.data.leagueId);

      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isLeagueAdmin(resource.data.leagueId)
        );

      allow update: if signedIn()
        && isLeagueAdmin(resource.data.leagueId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.userEmail == resource.data.userEmail
        && request.resource.data.leagueId == resource.data.leagueId
        && request.resource.data.status in ["approved", "rejected"];
    }

    match /matches/{matchId} {
      allow read: if isLeagueMember(resource.data.leagueId);
      allow create, update: if signedIn()
        && isLeagueAdmin(request.resource.data.leagueId)
        && request.resource.data.deadlineEpochMs is int;
      allow delete: if signedIn() && isLeagueAdmin(resource.data.leagueId);
    }

    match /picks/{pickId} {
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || isLeagueAdmin(resource.data.leagueId)
        );
      allow create, update: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userEmail == request.auth.token.email
        && isLeagueMember(request.resource.data.leagueId)
        && matchDeadlineIsOpen(request.resource.data.leagueId, request.resource.data.matchId);
    }

    match /leagueScores/{scoreId} {
      allow read: if signedIn() && isLeagueMember(resource.data.leagueId);
      allow create, update: if signedIn() && isLeagueAdmin(request.resource.data.leagueId);
      allow delete: if signedIn() && isLeagueAdmin(resource.data.leagueId);
    }
  }
}
